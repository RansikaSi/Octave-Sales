# Copy this file to .env.local and fill in real values for local dev.
# In Vercel, add the same keys under Project Settings -> Environment Variables
# (Production + Preview).

# Fine-grained GitHub PAT scoped to ONLY this repo, with
# "Contents: Read and write" permission and nothing else.
GITHUB_TOKEN=

GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main

# Shared passcode gating the /upload page and /api/update-data route.
UPDATE_PASSCODE=
